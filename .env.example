# ZIMA2_SSH_HOST / ZIMA2_SSH_USER / ZIMA2_SSH_PASSWORD
# SSH credentials for the second ZimaOS box ("ZimaOS Principal"), used to read
# its real CPU/GPU/RAM/disk stats and browse its files over SFTP.
ZIMA2_SSH_HOST="192.168.1.25"
ZIMA2_SSH_USER=""
ZIMA2_SSH_PASSWORD=""

# LOCAL_FILES_ROOT / REMOTE_FILES_ROOT
# Root directory exposed by the Fichiers page on each ZimaOS. Defaults to /DATA.
LOCAL_FILES_ROOT="/DATA"
REMOTE_FILES_ROOT="/DATA"
